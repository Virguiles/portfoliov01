# Headers pour optimiser le caching et les performances

# Cache agressif pour les ressources statiques
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Cache pour les images optimisées
/_next/image*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# Cache pour les polices
/_next/static/media/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# Cache pour les fichiers CSS et JS
/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

# Cache pour les images du site
/images/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# Cache pour les favicons
/favicon*
  Cache-Control: public, max-age=31536000, immutable

# Cache pour le manifest
/site.webmanifest
  Cache-Control: public, max-age=86400

# Cache pour le sitemap
/sitemap*
  Cache-Control: public, max-age=3600

# Cache pour les pages HTML (avec revalidation)
/
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/blog/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# Sécurité
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
