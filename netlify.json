{
  "build": {
    "environment": {
      "NODE_VERSION": "18",
      "NEXT_TELEMETRY_DISABLED": "1"
    }
  },
  "redirects": [
    {
      "from": "/locales/*",
      "to": "/locales/:splat",
      "status": 200
    },
    {
      "from": "/*",
      "to": "/index.html",
      "status": 200
    }
  ]
}
